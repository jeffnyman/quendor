{
  "$schema": "./node_modules/fallow/schema.json",
  "entry": ["src/index.{ts,tsx,js,jsx}", "src/main.{ts,tsx,js,jsx}"],
  "workspaces": {
    "patterns": ["apps/*", "packages/*", "tools/*"]
  },
  "duplicates": {
    "minOccurrences": 3
  },
  "rules": {},
  "health": {
    "maxCrap": 50,
    "thresholdOverrides": [
      {
        "files": ["packages/quendor/src/machine.ts"],
        "functions": ["execute"],
        "maxCyclomatic": 65535,
        "maxCognitive": 65535,
        "maxCrap": 65535,
        "maxUnitSize": 65535
      }
    ]
  }
}
