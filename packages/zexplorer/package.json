{
  "name": "zexplorer",
  "version": "0.0.0",
  "private": true,
  "description": "A Z-Machine explorer",
  "homepage": "https://jeffnyman.github.io/quendor/",
  "license": "MIT",
  "bin": {
    "zexp": "./dist-cli/cli.mjs"
  },
  "type": "module",
  "scripts": {
    "zexp": "node src/cli.ts",
    "dev": "vp dev --host --open",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cli.json && vp pack && vp build",
    "preview": "vp preview --host --open",
    "test": "vp test",
    "lint:css": "stylelint 'src/**/*.css'"
  },
  "dependencies": {
    "quendor": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "stylelint": "catalog:",
    "stylelint-config-standard": "catalog:",
    "stylelint-use-nesting": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  }
}
